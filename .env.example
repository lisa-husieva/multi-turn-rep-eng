# GPU device — controls which GPU is used by BOTH the notebook and vLLM server
# Change this one value and it propagates everywhere
CUDA_VISIBLE_DEVICES=4

# OpenAI — used for attacker (question generation) and judge (verdict)
OPENAI_API_KEY=

# vLLM — target model served locally
# Run scripts/launch_vllm.sh first, then set these
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=token-abc123

# Attacker and judge model names (OpenAI)
ATTACKER_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o
